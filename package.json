{
  "name": "postai",
  "version": "0.1.0",
  "description": "SaaS para criadores de conteúdo publicarem em múltiplas redes sociais via WhatsApp",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/integration",
    "test:load": "k6 run tests/load/main.js",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "typecheck": "tsc --noEmit",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "social-media",
    "whatsapp",
    "instagram",
    "tiktok",
    "linkedin",
    "youtube",
    "content-creator"
  ],
  "author": "Vinicius Santanna",
  "license": "UNLICENSED",
  "private": true
}
