{
  "name": "postai",
  "version": "0.1.0",
  "description": "SaaS para criadores de conteúdo publicarem em múltiplas redes sociais via WhatsApp",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:int": "vitest run tests/integration",
    "test:load": "k6 run tests/load/main.js",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "typecheck": "tsc --noEmit",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.73.1",
    "chrono-node": "^2.9.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.22.0",
    "resend": "^6.10.0",
    "sharp": "^0.34.5",
    "stripe": "^22.0.1",
    "tus-js-client": "^4.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.10",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.1",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "social-media",
    "whatsapp",
    "instagram",
    "tiktok",
    "linkedin",
    "youtube"
  ],
  "author": "Vinicius Santanna",
  "license": "UNLICENSED",
  "private": true
}
