# ============================================================
# PostAI — Environment Variables
# Copie para .env e preencha os valores
# NUNCA commite o .env real
# ============================================================

# Server
NODE_ENV=development
PORT=3000

# ============================================================
# Database (Supabase)
# ============================================================
# Formato: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ============================================================
# Supabase Storage
# ============================================================
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# Auth
# ============================================================
JWT_SECRET=CHANGE_ME_min_32_chars_random_string
JWT_REFRESH_SECRET=CHANGE_ME_another_min_32_chars_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# Encryption (para tokens OAuth — AES-256)
# ============================================================
ENCRYPTION_KEY=CHANGE_ME_exactly_32_chars_hex_key

# ============================================================
# Evolution API (WhatsApp)
# ============================================================
EVOLUTION_API_URL=https://evolution-evolution-api.6663ge.easypanel.host
EVOLUTION_API_KEY=puDnCkBgnR548fwLCMbVjHNJwxboR2sR
EVOLUTION_INSTANCE=postai

# ============================================================
# n8n Webhooks (VPS: n8neditor.n8nsupra.shop)
# ============================================================
N8N_WEBHOOK_PUBLISH=https://n8neditor.n8nsupra.shop/webhook/postai/publish
N8N_WEBHOOK_SCHEDULE=https://n8neditor.n8nsupra.shop/webhook/postai/schedule
N8N_WEBHOOK_RETRY=https://n8neditor.n8nsupra.shop/webhook/postai/retry

# ============================================================
# Stripe
# ============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_AGENCY=price_...

# ============================================================
# OAuth Credentials
# ============================================================

# Instagram / Facebook
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_REDIRECT_URI=https://api.postai.app/oauth/instagram/callback

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://api.postai.app/oauth/tiktok/callback

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://api.postai.app/oauth/linkedin/callback

# YouTube / Google
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://api.postai.app/oauth/youtube/callback

# ============================================================
# Frontend (Web App)
# ============================================================
FRONTEND_URL=http://localhost:3001

# ============================================================
# Monitoring (opcional no MVP)
# ============================================================
SENTRY_DSN=
